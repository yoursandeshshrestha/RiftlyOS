VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
VITE_ENVIRONMENT=development

# Resend (set in Supabase Edge Function secrets for send-email)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Agency OS <notifications@yourdomain.com>

# Stripe (secret key is also set in Supabase Edge Function secrets)
# STRIPE_SECRET_KEY=sk_test_...
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...  # from `stripe listen` when testing webhooks locally
VITE_APP_URL=http://localhost:5173
